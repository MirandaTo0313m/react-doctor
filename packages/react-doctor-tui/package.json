{
  "name": "react-doctor-tui",
  "version": "0.0.1",
  "private": true,
  "description": "Interactive terminal UI for react-doctor — live React code-health dashboard, watch mode, and diagnostic browser.",
  "keywords": [
    "cli",
    "code-health",
    "ink",
    "lint",
    "react",
    "react-doctor",
    "tui"
  ],
  "homepage": "https://github.com/millionco/react-doctor#readme",
  "bugs": {
    "url": "https://github.com/millionco/react-doctor/issues"
  },
  "license": "MIT",
  "author": "Aiden Bai",
  "repository": {
    "type": "git",
    "url": "https://github.com/millionco/react-doctor.git",
    "directory": "packages/react-doctor-tui"
  },
  "bin": {
    "react-doctor-tui": "./bin/react-doctor-tui.js"
  },
  "files": [
    "bin/**",
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && NODE_ENV=production vp pack",
    "typecheck": "tsc --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "ink": "^7.0.2",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.5",
    "react-doctor": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "ink-testing-library": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
